# ============================================================
# Optional: Firebase sync for progress + answer tracking.
#
# Without these vars the app still works fully — progress is
# kept in localStorage. With them, progress also syncs to
# Firestore under dmatProgress/{uid} via anonymous auth.
#
# Values: Firebase Console -> Project settings -> General ->
# "Your apps" -> Web app config. Also:
#   1. Enable Authentication -> Sign-in method -> Anonymous
#   2. Deploy the firestore rules addition (see README.md)
# ============================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=aws-certificate-9892b.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=aws-certificate-9892b
VITE_FIREBASE_APP_ID=
