# ============================================================
# Progress-API credentials (server-side only, like aws-learn-app).
#
# Set these on Vercel: Project -> Settings -> Environment Variables.
# They are the SAME service-account values aws-learn-app uses in its
# .env.local (Firebase Console -> Project settings -> Service
# accounts -> Generate new private key).
#
# Without them the app still works fully — progress just stays in
# each browser's localStorage instead of syncing to Firestore.
#
# Local dev: `npm run dev` has no /api (local-only mode). To run the
# API locally use `npx vercel dev` with these vars in .env.
# ============================================================
FIREBASE_PROJECT_ID=aws-certificate-9892b
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@aws-certificate-9892b.iam.gserviceaccount.com

# Keep the literal "\n" sequences inside the quotes — the API converts
# them to real newlines at runtime.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
